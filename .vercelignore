# .vercelignore — files and directories that must NOT be uploaded to Vercel.
#
# Vercel only needs the Next.js frontend in src/. Everything else in this repo
# (smart contracts, build output, local config, docs, tooling) is irrelevant to
# the deployment and is excluded here to keep uploads small and free of secrets.

# ─── Smart contracts and chain tooling (not part of the frontend) ─────────────
/contracts/
/artifacts/
/hardhat-cache/
/typechain-types/
/scripts/
/test/
/testing/
/tools/
/utils/
/stubs/

# ─── Local environment files - never upload secrets ───────────────────────────
.env
.env.*
!.env.example
!.env.local.example
.admin-bootstrap.generated.json

# ─── Build output (Vercel builds fresh on its own runners) ────────────────────
/node_modules/
/src/node_modules/
node_modules/
src/node_modules/
/.next/
src/.next/
/.swc/
src/.swc/
/.turbo/
src/.turbo/
/.vercel/output/
/.vercel/cache/
src/.vercel/
/dist/
/target/
target/
/programs/*/target/
/contracts/out/
/contracts/cache/
*.tsbuildinfo
src/out/
/coverage/
src/coverage/
src/test-results/
src/playwright-report/
src/.playwright-cli/
.lighthouseci/
src/.lighthouseci/
.mypy_cache/
.venv-docs/
.git/

# ─── Non-frontend runtimes and local package caches ──────────────────────────
/.cargo/
/infra/
/lib/
/programs/
/foundry-sandbox/
/contracts/lib/
/tmp/

# ─── Debug / profiling output ─────────────────────────────────────────────────
*.cpuprofile
*.log
/logs/
/trace/

# ─── Containers (Vercel does not use the Docker setup) ────────────────────────
/docker/
/Dockerfile
/docker-compose.yml
/.dockerignore

# ─── Documentation site and project docs ──────────────────────────────────────
/docs/
/site/
/assets/*
!/assets/analytics/
!/assets/analytics/*.json
!/assets/analytics/*.svg
/mkdocs.yml
/requirements-docs.txt

# ─── Editor, agent, and OS generated files ────────────────────────────────────
.vscode/
.claude/
.serena/
.DS_Store
Thumbs.db

{
	"$schema": "https://unpkg.com/knip@6/schema.json",
	"paths": {
		"@/*": ["./*"]
	},
	"entry": [
		"security/index.ts!",
		"core/index.ts!",
		"core/ai/index.ts!",
		"lib/db/index.ts!",
		"prisma.config.ts",
		"scripts/*.mjs"
	],
	"ignoreFiles": [
		".next/**",
		".vercel/**",
		"app/helpers.css",
		"components/ReactScanMonitor.tsx",
		"coverage/**",
		"doctor.config.ts",
		"env.d.ts",
		"jest.setup.ts",
		"lib/generated/**",
		"playwright-report/**",
		"test-results/**"
	],
	"ignoreDependencies": ["@prisma/client", "pg", "prisma", "server-only"],
	"ignoreIssues": {
		"components/ReactScanMonitor.tsx": ["unlisted"],
		"controllers/accountProfileController.ts": ["unlisted"],
		"controllers/result.ts": ["unlisted"],
		"lib/accountPreferences.ts": ["exports"],
		"lib/solanaEscrow.ts": ["exports"],
		"lib/staking/assets.ts": ["exports"],
		"lib/staking/execution.ts": ["exports"],
		"lib/wagmi.ts": ["exports"],
		"services/contractSummary.ts": ["exports", "types", "unlisted"],
		"services/health.ts": ["types"],
		"services/offchainAccounts.ts": ["exports", "unlisted"],
		"services/oracle.ts": ["exports", "types"],
		"types/contract.ts": ["exports", "types"],
		"types/dispute.ts": ["exports", "types"],
		"types/index.ts": ["exports"],
		"types/rating.ts": ["types"]
	}
}

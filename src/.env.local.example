# Copy this file to src/.env.local and fill in the values.
# Vercel CLI populates VERCEL_OIDC_TOKEN automatically during `vercel env pull`;
# you do not need to set it manually for local development.
VERCEL_OIDC_TOKEN=

# Contract addresses deployed to your local Anvil node (or the target network).
# Run `npm run sync-env` (or the deploy script) to populate these automatically
# from artifacts/deployed-addresses.json after a fresh deployment.
NEXT_PUBLIC_TRUSTLEDGER_ADDRESS=0x
NEXT_PUBLIC_ARBITRATION_ADDRESS=0x
NEXT_PUBLIC_JUROR_REGISTRY_ADDRESS=0x
NEXT_PUBLIC_REPUTATION_REGISTRY_ADDRESS=0x
NEXT_PUBLIC_TRUSTLEDGER_DEPLOY_BLOCK=

# Optional local-only render diagnostic overlay. Keep disabled for accessibility
# testing because the third-party overlay controls are not part of TrustLedger UI.
NEXT_PUBLIC_ENABLE_REACT_SCAN=false

# WalletConnect/Reown AppKit project ID. Public browser config, not a secret.
# Get it from https://dashboard.reown.com by creating an AppKit project.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Public frontend origins. NEXT_PUBLIC_SITE_URL is the wallet metadata fallback;
# NEXT_PUBLIC_APP_URL is also used when creating magic-link URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_GITHUB_URL=
# Documentation site link shown in the navbar; leave empty to hide the Docs link.
NEXT_PUBLIC_DOCS_URL=

# Optional server-only token for higher GitHub API rate limits. Private repos
# remain hidden from public analytics even when this token can access them.
GITHUB_TOKEN=

# Optional public Solana cluster label for native-program support. Allowed:
# devnet, testnet, mainnet-beta, localnet. Defaults to devnet when unset.
NEXT_PUBLIC_SOLANA_CLUSTER=devnet

# Optional token-address overrides. Leave blank to use src/lib/wagmi.ts defaults.
NEXT_PUBLIC_USDC_ADDRESS_SEPOLIA=
NEXT_PUBLIC_USDC_ADDRESS_ARBITRUM=
NEXT_PUBLIC_USDC_ADDRESS_BASE=
NEXT_PUBLIC_USDC_ADDRESS_OPTIMISM=

# Network-specific contract addresses for non-default chains.
NEXT_PUBLIC_TRUSTLEDGER_ADDRESS_SEPOLIA=
NEXT_PUBLIC_ARBITRATION_ADDRESS_SEPOLIA=
NEXT_PUBLIC_JUROR_REGISTRY_ADDRESS_SEPOLIA=
NEXT_PUBLIC_REPUTATION_REGISTRY_ADDRESS_SEPOLIA=
NEXT_PUBLIC_TRUSTLEDGER_DEPLOY_BLOCK_SEPOLIA=
NEXT_PUBLIC_TRUSTLEDGER_ADDRESS_ARBITRUM=
NEXT_PUBLIC_ARBITRATION_ADDRESS_ARBITRUM=
NEXT_PUBLIC_JUROR_REGISTRY_ADDRESS_ARBITRUM=
NEXT_PUBLIC_REPUTATION_REGISTRY_ADDRESS_ARBITRUM=
NEXT_PUBLIC_TRUSTLEDGER_DEPLOY_BLOCK_ARBITRUM=
NEXT_PUBLIC_TRUSTLEDGER_ADDRESS_BASE=
NEXT_PUBLIC_ARBITRATION_ADDRESS_BASE=
NEXT_PUBLIC_JUROR_REGISTRY_ADDRESS_BASE=
NEXT_PUBLIC_REPUTATION_REGISTRY_ADDRESS_BASE=
NEXT_PUBLIC_TRUSTLEDGER_DEPLOY_BLOCK_BASE=
NEXT_PUBLIC_TRUSTLEDGER_ADDRESS_OPTIMISM=
NEXT_PUBLIC_ARBITRATION_ADDRESS_OPTIMISM=
NEXT_PUBLIC_JUROR_REGISTRY_ADDRESS_OPTIMISM=
NEXT_PUBLIC_REPUTATION_REGISTRY_ADDRESS_OPTIMISM=
NEXT_PUBLIC_TRUSTLEDGER_DEPLOY_BLOCK_OPTIMISM=

# Server-side Sepolia RPC URL. Required by the contract-summary route
# (/api/contract/[id]/summary) to read on-chain contract data. Next.js loads this
# file at runtime; the repo-root .env is not read by the frontend server.
SEPOLIA_RPC_URL=

# AI infrastructure (server-side, provider-agnostic via @/core/ai). Powers the
# contract-summary service (/api/contract/[id]/summary) and /api/ai/complete.
# With nothing set the app runs the built-in `disabled` placeholder — no calls.
# Keep it disabled until provider data-use controls and monitoring are ready.
# Production/preview values live in the Vercel project env, not this file.
#
# OpenAI-compatible (OpenAI, Groq, OpenRouter, NVIDIA, a gateway, self-hosted):
#   AI_PROVIDER_KIND=openai-compatible
#   AI_BASE_URL=https://api.groq.com/openai/v1
#   AI_API_KEY=
#   AI_DEFAULT_MODEL=llama-3.3-70b-versatile
# Google Gemini (built-in adapter; base URL is optional):
#   AI_PROVIDER_KIND=gemini
#   AI_API_KEY=
#   AI_DEFAULT_MODEL=gemini-2.5-flash
# AI_ENABLED=false forces the placeholder even when a provider is configured.
AI_ENABLED=
AI_PROVIDER_KIND=
AI_BASE_URL=
AI_API_KEY=
AI_DEFAULT_MODEL=
# OpenRouter fallback (free tier available). Used automatically when the
# primary provider above errors or is unconfigured. Get a key at
# https://openrouter.ai/keys.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=
AI_FALLBACK_MODEL=

# ── Off-chain database (PostgreSQL via Prisma) ──────────────────────────────
# Next.js runs from src/ and does NOT read the repository-root .env, so the
# database + account features need these here (in src/.env.local) as well.
#   DATABASE_URL - pooled connection used by the app at runtime.
#   DIRECT_URL   - direct (non-pooled) connection used by `prisma migrate`. For
#                  Neon this is DATABASE_URL with the "-pooler" segment removed.
DATABASE_URL=
DIRECT_URL=

# ── Server-side auth / notification secrets (generate: openssl rand -hex 32) ──
# Required by the account, magic-link, notification, and cron API routes served
# from src/. Never commit real values; production values live in Vercel.
ACCOUNT_SESSION_SECRET=
AUTH_JWT_SECRET=
MAGIC_LINK_SECRET=
CRON_SECRET=
NOTIFICATIONS_SECRET=
INTERNAL_API_TOKEN=
# STOPGAP address->email JSON for the deadline-reminder cron, used only when the
# off-chain account database has no email on file. Example:
#   NOTIFICATION_EMAILS={"0xabc...":"user@example.com"}
NOTIFICATION_EMAILS=

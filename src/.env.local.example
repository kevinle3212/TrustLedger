# Copy this file to src/.env.local and fill in the values.
# Vercel CLI populates VERCEL_OIDC_TOKEN automatically during `vercel env pull`;
# you do not need to set it manually for local development.
VERCEL_OIDC_TOKEN=

# Contract addresses deployed to your local Anvil node (or the target network).
# Run `npm run sync-env` (or the deploy script) to populate these automatically
# from artifacts/deployed-addresses.json after a fresh deployment.
NEXT_PUBLIC_TRUSTLEDGER_ADDRESS=0x
NEXT_PUBLIC_ARBITRATION_ADDRESS=0x
NEXT_PUBLIC_JUROR_REGISTRY_ADDRESS=0x
NEXT_PUBLIC_REPUTATION_REGISTRY_ADDRESS=0x

# ── IPFS pinning (services/ipfs.ts) ─────────────────────────────────────────
# Pinata JWT obtained from app.pinata.cloud → API Keys → New Key.
# Required for pinJson, pinFile, and unpin.
PINATA_JWT=
# Optional: override the default Pinata public gateway for IPFS content URLs.
# Default: https://gateway.pinata.cloud/ipfs
# PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs

# ── AI summaries (services/aiSummary.ts) ────────────────────────────────────
# Anthropic API key from console.anthropic.com → API Keys.
# Required for summarizeContract and summarizeDispute.
ANTHROPIC_API_KEY=

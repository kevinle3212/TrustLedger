{
	"$schema": "https://json.schemastore.org/swcrc",
	"jsc": {
		"target": "es2024",
		"parser": {
			"syntax": "typescript",
			"tsx": true,
			"decorators": false,
			"dynamicImport": true
		},
		"transform": {
			"react": {
				"runtime": "automatic",
				"development": false,
				"refresh": false,
				"useBuiltins": true
			}
		},
		"externalHelpers": true,
		"loose": false,
		"preserveAllComments": false
	},
	"module": {
		"type": "es6",
		"strict": true,
		"strictMode": true,
		"lazy": false,
		"noInterop": false
	},
	"sourceMaps": true,
	"inlineSourcesContent": false,
	"minify": false,
	"isModule": "unknown"
}

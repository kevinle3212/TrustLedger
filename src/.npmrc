# ─── npm configuration (src/ frontend workspace) ─────────────────────────────
# Skip the audit + funding messages on install; dependency and vulnerability
# scanning runs in CI (security.yml / dependency-auditor) rather than per-install.
audit=false
fund=false
# Only surface errors during frontend installs (keeps CI logs focused).
loglevel=error
# Supply-chain delay: only install package versions published more than 7 days
# ago, giving compromised releases time to be caught and yanked (npm-native).
min-release-age=7

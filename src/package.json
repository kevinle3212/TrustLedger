{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "frontend",
	"version": "0.1.0",
	"description": "TrustLedger frontend - Next.js 16 dApp for interacting with the TrustLedger smart contract on Ethereum Sepolia.",
	"private": true,
	"keywords": [
		"ethereum",
		"smart-contract",
		"blockchain",
		"ledger",
		"next.js",
		"react",
		"trustledger",
		"dapp",
		"web3",
		"escrow",
		"freelance",
		"dispute-resolution",
		"wagmi",
		"viem",
		"tailwindcss",
		"typescript",
		"walletconnect",
		"appkit",
		"frontend"
	],
	"homepage": "https://github.com/kevinle3212/TrustLedger/blob/main/src/README.md",
	"bugs": {
		"url": "https://github.com/kevinle3212/TrustLedger/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kevinle3212/TrustLedger.git"
	},
	"license": "Apache-2.0",
	"author": "Kevin Le, Kellen Snider",
	"engines": {
		"node": ">=22.0.0"
	},
	"packageManager": "npm@11.12.1",
	"scripts": {
		"dev:frontend": "NODE_OPTIONS='--disable-warning=DEP0205' next dev",
		"swc:populate": "node ../tools/ensure-swc-cache.mjs",
		"prebuild:frontend": "npm run swc:populate",
		"build:frontend": "NODE_OPTIONS='--disable-warning=DEP0205' next build",
		"vercel-build": "next build",
		"start:frontend": "next start",
		"typecheck": "npx tsc --noEmit",
		"quality": "npm run typecheck && npm run lint:frontend && npm run test:unit",
		"quality:all": "npm run quality && npm run build:frontend && npm run doctor && npm run test:e2e",
		"lint:frontend": "npm run lint:frontend:ts && npm run lint:frontend:prettier",
		"lint:frontend:ts": "eslint app lib components contexts services store utils hooks providers tests proxy.ts playwright.config.ts",
		"lint:frontend:prettier": "prettier --check \"app/**\" \"lib/**\" \"components/**\" \"contexts/**\" \"services/**\" \"store/**\" \"utils/**\" \"hooks/**\" \"providers/**\" \"tests/**\" \"proxy.ts\" \"next.config.ts\" \"playwright.config.ts\"",
		"fix:frontend": "npm run fix:frontend:ts && npm run fix:frontend:prettier",
		"fix:frontend:ts": "eslint --fix app lib components contexts services store utils hooks providers tests proxy.ts playwright.config.ts",
		"fix:frontend:prettier": "prettier --write \"app/**\" \"lib/**\" \"components/**\" \"contexts/**\" \"services/**\" \"store/**\" \"utils/**\" \"hooks/**\" \"providers/**\" \"tests/**\" \"proxy.ts\" \"next.config.ts\" \"playwright.config.ts\"",
		"debug:frontend:files": "tsc -p tsconfig.debug.json --generateTrace ./trace --generateCpuProfile ./profile.cpuprofile",
		"cache:clear": "npm run cache:clear:eslint && npm run cache:clear:prettier && npm run cache:clear:npm && npm run cache:clear:next",
		"cache:clear:eslint": "find . -name '.eslintcache' -maxdepth 3 | grep -v node_modules | xargs rm -f",
		"cache:clear:prettier": "find . -name '.prettiercache' -maxdepth 3 | grep -v node_modules | xargs rm -f",
		"cache:clear:npm": "npm cache clean --force",
		"cache:clear:next": "rm -rf .next",
		"doctor": "react-doctor",
		"test": "jest",
		"test:unit": "jest --runInBand",
		"test:coverage": "jest --coverage",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:headed": "playwright test --headed",
		"install:playwright": "playwright install chromium"
	},
	"dependencies": {
		"@reown/appkit": "^1.8.20",
		"@reown/appkit-adapter-wagmi": "^1.8.20",
		"@tanstack/react-query": "^5.100.10",
		"arweave": "^1.15.7",
		"next": "16.2.6",
		"next-intl": "^4.13.0",
		"next-themes": "^0.4.6",
		"react": "19.2.6",
		"react-dom": "19.2.6",
		"resend": "^6.12.3",
		"viem": "^2.49.3",
		"wagmi": "^2.19.5"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.11.3",
		"@eslint/js": "^9.39.4",
		"@playwright/test": "^1.60.0",
		"@tailwindcss/postcss": "^4.3.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.0",
		"@types/jest": "^30.0.0",
		"@types/node": "^25.8.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"eslint": "^9.39.4",
		"eslint-config-next": "16.2.6",
		"eslint-config-prettier": "^10.1.8",
		"jest": "^30.2.0",
		"jest-environment-jsdom": "^30.2.0",
		"playwright": "^1.60.0",
		"prettier": "^3.8.3",
		"react-doctor": "^0.4.0",
		"react-scan": "^0.5.7",
		"sass": "^1.100.0",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.3"
	},
	"overrides": {
		"ws": "8.20.1",
		"postcss": "8.5.10",
		"uuid": "11.1.1"
	}
}

{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "frontend",
	"version": "0.1.0",
	"description": "TrustLedger frontend - Next.js 16 dApp for interacting with the TrustLedger smart contract on Ethereum Sepolia.",
	"private": true,
	"keywords": [
		"ethereum",
		"smart-contract",
		"blockchain",
		"ledger",
		"next.js",
		"react",
		"trustledger",
		"dapp",
		"web3",
		"escrow",
		"freelance",
		"dispute-resolution",
		"wagmi",
		"viem",
		"tailwindcss",
		"typescript",
		"walletconnect",
		"appkit",
		"frontend"
	],
	"homepage": "https://github.com/kevinle3212/TrustLedger/blob/main/src/README.md",
	"bugs": {
		"url": "https://github.com/kevinle3212/TrustLedger/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kevinle3212/TrustLedger.git"
	},
	"license": "Apache-2.0",
	"author": "Kevin Le <https://www.linkedin.com/in/lekevin1>",
	"contributors": [
		"Kevin Le <https://www.linkedin.com/in/lekevin1>",
		"Kellen Snider <https://www.linkedin.com/in/kellen-snider-683396256/>"
	],
	"authorsAndContributors": [
		{
			"name": "Kevin Le",
			"url": "https://www.linkedin.com/in/lekevin1"
		},
		{
			"name": "Kellen Snider",
			"url": "https://www.linkedin.com/in/kellen-snider-683396256/"
		}
	],
	"engines": {
		"node": ">=22.0.0 <23"
	},
	"packageManager": "npm@11.12.1",
	"scripts": {
		"postinstall": "patch-package && npm run db:generate",
		"dev:frontend": "NODE_OPTIONS=--no-experimental-webstorage next dev",
		"swc:populate": "node ../tools/ensure-swc-cache.mjs",
		"stats:generate": "node scripts/generate-codebase-stats.mjs",
		"db:generate": "prisma generate",
		"db:migrate": "prisma migrate deploy",
		"db:migrate:dev": "prisma migrate dev",
		"db:studio": "prisma studio",
		"prebuild:frontend": "npm run swc:populate && npm run db:generate",
		"build:frontend": "npm run stats:generate && NODE_OPTIONS=--no-experimental-webstorage next build",
		"vercel-build": "npm run db:generate && npm run stats:generate && NODE_OPTIONS=--no-experimental-webstorage next build",
		"start:frontend": "NODE_OPTIONS=--no-experimental-webstorage next start",
		"start:e2e:standalone": "NODE_OPTIONS=--no-experimental-webstorage node ../tools/start-standalone-e2e.mjs",
		"typecheck": "npx tsc --noEmit",
		"quality": "npm run typecheck && npm run lint:frontend && npm run i18n:scan && npm run test:unit",
		"quality:all": "npm run quality && npm run build:frontend && npm run doctor && npm run test:e2e",
		"lint:frontend": "npm run lint:frontend:ts && npm run lint:frontend:prettier",
		"lint:frontend:ts": "eslint app core lib components contexts services store utils hooks providers security tests proxy.ts playwright.config.ts",
		"lint:frontend:prettier": "prettier --check \"app/**\" \"core/**\" \"lib/**\" \"components/**\" \"contexts/**\" \"services/**\" \"store/**\" \"utils/**\" \"hooks/**\" \"providers/**\" \"security/**\" \"tests/**\" \"proxy.ts\" \"next.config.ts\" \"playwright.config.ts\"",
		"fix:frontend": "npm run fix:frontend:ts && npm run fix:frontend:prettier",
		"fix:frontend:ts": "eslint --fix app lib components contexts services store utils hooks providers security tests proxy.ts playwright.config.ts",
		"fix:frontend:prettier": "prettier --write \"app/**\" \"lib/**\" \"components/**\" \"contexts/**\" \"services/**\" \"store/**\" \"utils/**\" \"hooks/**\" \"providers/**\" \"security/**\" \"tests/**\" \"proxy.ts\" \"next.config.ts\" \"playwright.config.ts\"",
		"debug:frontend:files": "tsc -p tsconfig.debug.json --generateTrace ./trace --generateCpuProfile ./profile.cpuprofile",
		"cache:clear": "npm run cache:clear:eslint && npm run cache:clear:prettier && npm run cache:clear:npm && npm run cache:clear:next",
		"cache:clear:eslint": "find . -name '.eslintcache' -maxdepth 3 | grep -v node_modules | xargs rm -f",
		"cache:clear:prettier": "find . -name '.prettiercache' -maxdepth 3 | grep -v node_modules | xargs rm -f",
		"cache:clear:npm": "npm cache clean --force",
		"cache:clear:next": "rm -rf .next",
		"doctor": "react-doctor",
		"test": "jest",
		"test:unit": "jest --runInBand",
		"i18n:scan": "jest --runInBand tests/unit/no-visible-jsx-literals.test.ts tests/unit/locale-messages.test.ts",
		"test:coverage": "jest --coverage",
		"test:e2e": "NODE_OPTIONS=--no-experimental-webstorage env -u NO_COLOR playwright test --grep-invert @wallet",
		"test:e2e:wallet": "NODE_OPTIONS=--no-experimental-webstorage env -u NO_COLOR playwright test --project=chromium --grep @wallet",
		"test:e2e:ui": "NODE_OPTIONS=--no-experimental-webstorage playwright test --ui",
		"test:e2e:headed": "NODE_OPTIONS=--no-experimental-webstorage playwright test --headed",
		"install:playwright": "playwright install chromium"
	},
	"dependencies": {
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"@reown/appkit": "^1.8.20",
		"@reown/appkit-adapter-wagmi": "^1.8.20",
		"@solana/web3.js": "^1.98.4",
		"@tanstack/react-query": "^5.100.10",
		"arweave": "^1.15.7",
		"next": "^16.2.9",
		"next-intl": "^4.13.0",
		"next-themes": "^0.4.6",
		"pg": "^8.22.0",
		"prisma": "^7.8.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"recharts": "^3.8.1",
		"resend": "^6.12.3",
		"viem": "^2.49.3",
		"wagmi": "^2.19.5"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.11.3",
		"@eslint/js": "^9.39.4",
		"@playwright/test": "^1.61.1",
		"@tailwindcss/postcss": "^4.3.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.0",
		"@types/jest": "^30.0.0",
		"@types/node": "^25.8.0",
		"@types/pg": "^8.20.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"eslint": "^9.39.4",
		"eslint-config-next": "^16.2.9",
		"eslint-config-prettier": "^10.1.8",
		"jest": "^30.2.0",
		"jest-environment-jsdom": "^30.2.0",
		"patch-package": "^8.0.1",
		"playwright": "^1.61.1",
		"prettier": "^3.8.4",
		"react-doctor": "^0.5.1",
		"react-scan": "^0.5.7",
		"sass": "^1.100.0",
		"tailwindcss": "^4.3.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.3"
	},
	"overrides": {
		"ws": "8.21.0",
		"postcss": "8.5.10",
		"uuid": "11.1.1",
		"form-data": "4.0.6",
		"hono": "4.12.26",
		"js-yaml": "4.2.0",
		"@istanbuljs/load-nyc-config": {
			"js-yaml": "3.15.0"
		}
	}
}

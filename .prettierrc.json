{
	"printWidth": 100,
	"tabWidth": 4,
	"useTabs": true,
	"semi": true,
	"singleQuote": false,
	"quoteProps": "consistent",
	"trailingComma": "all",
	"bracketSpacing": true,
	"bracketSameLine": false,
	"arrowParens": "always",
	"endOfLine": "lf",
	"embeddedLanguageFormatting": "auto",
	"proseWrap": "preserve",
	"htmlWhitespaceSensitivity": "css",
	"experimentalTernaries": false,
	"singleAttributePerLine": false,
	"overrides": [
		{
			"files": ["*.md", "*.markdown"],
			"options": {
				"useTabs": false,
				"tabWidth": 2,
				"proseWrap": "always",
				"printWidth": 80
			}
		}
	]
}

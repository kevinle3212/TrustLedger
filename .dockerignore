# ─── JavaScript / Node ────────────────────────────────────────────────────────
# Installed by npm ci inside the image; host copy would overwrite the wrong arch
node_modules/
dist/
*.tsbuildinfo

# ─── Hardhat build output ─────────────────────────────────────────────────────
artifacts/
hardhat-cache/

# ─── Foundry build output ─────────────────────────────────────────────────────
contracts/out/
contracts/cache/
contracts/broadcast/

# ─── Secrets - never bake into an image ───────────────────────────────────────
.env
.env.*
!.env.example

# ─── Debug / profiling output ─────────────────────────────────────────────────
*.cpuprofile
trace/

# ─── Test coverage ────────────────────────────────────────────────────────────
coverage/

# ─── Package manager caches ───────────────────────────────────────────────────
.npm
.pnpm-store

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log

# ─── Git internals - not needed in the image; submodule content is in contracts/lib/
.git/
.gitmodules

# ─── OS / editor generated files ──────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.claude/

# ─── Next.js build output ─────────────────────────────────────────────────────
src/.next/
src/out/

# ─── Local testing docs (not needed inside the image) ─────────────────────────
testing/

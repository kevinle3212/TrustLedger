# ─── JavaScript / Node ────────────────────────────────────────────────────────
# Installed by npm ci inside the image; host copy would overwrite the wrong arch
node_modules/
src/node_modules/
dist/
*.tsbuildinfo

# ─── Hardhat build output ─────────────────────────────────────────────────────
artifacts/
hardhat-cache/

# ─── Foundry build output ─────────────────────────────────────────────────────
contracts/out/
contracts/cache/
contracts/broadcast/

# ─── Secrets - never bake into an image ───────────────────────────────────────
.env
.env.*
**/.env
**/.env.*
!.env.example
!**/.env.example
!**/.env.local.example

# ─── Debug / profiling output ─────────────────────────────────────────────────
*.cpuprofile
trace/

# ─── Test coverage ────────────────────────────────────────────────────────────
coverage/
src/coverage/
src/playwright-report/
src/test-results/

# ─── Package manager caches ───────────────────────────────────────────────────
.npm
.pnpm-store

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log

# ─── Owner-reviewed legal drafts - publish only after approval ───────────────
ACCEPTABLE_USE_POLICY.md
COMMUNITY_GUIDELINES.md
CONTENT_POLICY.md
COOKIE_POLICY.md
DISCLAIMER.md
DISCLAIMER 2.md
DMCA_POLICY.md
PRIVACY_POLICY.md
RISK_DISCLOSURE.md
TERMS_AND_CONDITIONS.md
TRADEMARK_POLICY.md

# ─── Git internals - not needed in the image; submodule content is in contracts/lib/
.git/
.gitmodules

# ─── OS / editor generated files ──────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.claude/

# ─── Next.js build output ─────────────────────────────────────────────────────
src/.next/
src/out/

# ─── Local testing docs (not needed inside the image) ─────────────────────────
testing/
site/
.serena/
.nexus/
.impeccable/

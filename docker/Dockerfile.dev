ARG FOUNDRY_TAG=v1.5.1
ARG NODE_VERSION=22

FROM ghcr.io/foundry-rs/foundry:${FOUNDRY_TAG} AS foundry-base

FROM node:${NODE_VERSION}-slim AS dev

COPY --from=foundry-base /usr/local/bin/forge /usr/local/bin/forge
COPY --from=foundry-base /usr/local/bin/cast  /usr/local/bin/cast
COPY --from=foundry-base /usr/local/bin/anvil /usr/local/bin/anvil

RUN apt-get update \
    && apt-get install -y --no-install-recommends bash git curl ca-certificates python3 make g++ \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY src/package.json src/package-lock.json ./src/
RUN cd src && npm ci

COPY . .

RUN git submodule update --init --recursive 2>/dev/null || true

RUN npm run compile \
    && cd contracts && forge build

EXPOSE 8545

HEALTHCHECK --interval=10s --timeout=5s --start-period=20s --retries=12 \
    CMD cast block-number --rpc-url http://127.0.0.1:8545 >/dev/null 2>&1 || exit 1

ENTRYPOINT ["bash", "scripts/docker-demo.sh"]

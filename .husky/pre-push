set -e
echo "pre-push: duplicate scan"
bash tools/remove-duplicates.sh --fail-on-found .
echo "pre-push: sensitive files"
npm run secrets:check
echo "pre-push: SWC cache"
npm run swc:populate
echo "pre-push: logs"
npm run logs:check
echo "pre-push: tmp"
npm run tmp:check
echo "pre-push: Docker storage"
npm run docker:storage:prune
echo "pre-push: native"
npm run native:check
echo "pre-push: analytics"
npm run analytics:check
echo "pre-push: docs navigation"
npm run docs:nav:check
echo "pre-push: quality"
npm run quality
echo "pre-push: frontend build"
npm run build:frontend
echo "pre-push: frontend E2E"
(cd src && CI=1 PORT=3100 npm run test:e2e)
echo "pre-push: impeccable checks"
CI=1 PORT=3100 npm run impeccable
echo "pre-push: Rust backend"
npm run rust:fmt
npm run rust:clippy
npm run rust:test
echo "pre-push: Solana program"
npm run solana:program:fmt
npm run solana:program:check
echo "pre-push: contracts"
FOUNDRY_PROFILE=ci node tools/foundry-sandbox.mjs build
FOUNDRY_PROFILE=ci node tools/foundry-sandbox.mjs test

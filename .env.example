# ─── TrustLedger environment variables ────────────────────────────────────────
#
# Copy this file to .env and fill in each value before running scripts.
# Consumed by:
#   scripts/deploy.ts        — deployment to Arbitrum Sepolia
#   scripts/check-balance.ts — pre-deploy balance check
#   hardhat.config.ts        — network configuration + Etherscan verification
#   .github/workflows/deploy.yml — CI/CD secrets (ARBITRUM_SEPOLIA_RPC_URL,
#                                  DEPLOYER_PRIVATE_KEY, ETHERSCAN_API_KEY)
#
# Never commit your real .env file. .gitignore already excludes it.

# ─── RPC endpoint ─────────────────────────────────────────────────────────────
# HTTP JSON-RPC URL for Arbitrum Sepolia (testnet).
# Free options:
#   • Alchemy  — sign up at alchemy.com, create an app, select "Arbitrum Sepolia",
#                copy the HTTPS endpoint (looks like https://arb-sepolia.g.alchemy.com/v2/<key>)
#   • Infura   — sign up at infura.io, create a project, enable "Arbitrum Sepolia",
#                copy the endpoint (looks like https://arbitrum-sepolia.infura.io/v3/<key>)
#   • Public   — the default below works for low-volume testing but may be rate-limited
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# ─── Deployer wallet — public address ─────────────────────────────────────────
# The 0x… address of the wallet that will sign and pay for deployments.
# How to get it:
#   • MetaMask — open the extension, your address is shown at the top of the account view
#   • Cast     — run: cast wallet address --interactive   (enter your private key when prompted)
# You will need testnet ETH on Arbitrum Sepolia to cover gas:
#   • Official faucet : faucet.arbitrum.io
#   • Alchemy faucet  : alchemy.com/faucets/arbitrum-sepolia
#   • Sepolia bridge  : bridge.arbitrum.io (bridge Sepolia ETH → Arbitrum Sepolia)
DEPLOYER_PUBLIC_ADDRESS=

# ─── Deployer wallet — private key ────────────────────────────────────────────
# ⚠️  NEVER share this value or commit it to version control.
# The raw hex private key (with or without the leading 0x) for the deployer wallet.
# How to export it:
#   • MetaMask — Settings → Accounts → (select account) → Show private key → enter password
#   • Cast     — run: cast wallet new   to generate a fresh throwaway wallet for testing
# Tip: use a dedicated testnet-only wallet — never use a wallet that holds real funds.
DEPLOYER_PRIVATE_KEY=

# ─── Etherscan / Arbiscan API key ─────────────────────────────────────────────
# Used by Hardhat's verify plugin to publish and verify contract source on Arbiscan.
# The same key works for both Arbitrum Mainnet and Arbitrum Sepolia.
# How to get it:
#   1. Register at arbiscan.io/register
#   2. Log in and go to arbiscan.io/myapikey
#   3. Click "Add" to create a new API key and copy the value
ETHERSCAN_API_KEY=

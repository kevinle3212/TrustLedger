# ─── TrustLedger environment variables ───────────────────────────────────────
#
# Copy this file to .env and fill in each value before running scripts.
# Consumed by:
#   hardhat.config.ts             - network config and Etherscan verification
#   scripts/deploy.ts             - Hardhat deployment to Ethereum Sepolia
#   contracts/foundry.toml        - Foundry RPC endpoints and Etherscan config
#   src/next.config.ts            - injected as NEXT_PUBLIC_* at build time
#   .github/workflows/deploy.yml  - CI/CD secrets
#
# Never commit your real .env file - .gitignore already excludes it.
# Any value that is safe to expose can be chosen to be kept secret or public
# (NEXT_PUBLIC_ prefix) - it's up to the project specs and discretion.
# If in doubt, treat it as a secret and do not commit it.

# ─── RPC endpoint [REQUIRED for contract deployment / Foundry fork tests] ─────
# HTTP JSON-RPC URL for Ethereum Sepolia (chain ID 11155111).
# Also used by Foundry fork tests (test/fork/**) via vm.envOr("SEPOLIA_RPC_URL").
#   Alchemy : https://eth-sepolia.g.alchemy.com/v2/<key>  (alchemy.com)
#   Infura  : https://sepolia.infura.io/v3/<key>          (infura.io)
SEPOLIA_RPC_URL=

# ─── Deployer wallet [REQUIRED for contract deployment] ───────────────────────
# Reference only - not consumed by any config file. Useful to keep track of
# which address is funding and signing deploys.
# The 0x… address shown at the top of your MetaMask account view.
# Fund it with Sepolia ETH before deploying:
#   Alchemy faucet : alchemy.com/faucets/ethereum-sepolia
#   Infura faucet  : infura.io/faucet/sepolia
#   Google faucet  : cloud.google.com/application/web3/faucet/ethereum/sepolia
DEPLOYER_PUBLIC_ADDRESS=

# ⚠️  NEVER share or commit this value.
# Export from MetaMask: Settings → Accounts → Show private key
# Or generate a fresh throwaway wallet: cast wallet new
DEPLOYER_PRIVATE_KEY=

# ─── Etherscan verification [REQUIRED for --verify during Sepolia deploys] ────
# ⚠️  NEVER share or commit this value.
# Required for --verify during testnet deploys (npm run foundry:deploy:sepolia).
# Get a free key at etherscan.io/register → My API Keys
ETHERSCAN_API_KEY=

# ─── Infura API key [OPTIONAL - reference only, not consumed by any code] ─────
# Infura is a hosted Ethereum node provider - an alternative to Alchemy.
# Not directly consumed by hardhat.config.ts or foundry.toml. Use this key to
# construct SEPOLIA_RPC_URL (and the L2 URLs below) following these formats:
#   Sepolia    : https://sepolia.infura.io/v3/<INFURA_API_KEY>
#   Arbitrum   : https://arbitrum-mainnet.infura.io/v3/<INFURA_API_KEY>
#   Base       : https://base-mainnet.infura.io/v3/<INFURA_API_KEY>
#   Optimism   : https://optimism-mainnet.infura.io/v3/<INFURA_API_KEY>
#   Mainnet    : https://mainnet.infura.io/v3/<INFURA_API_KEY>
#
# You only need ONE of (Alchemy / Infura) - pick whichever you already have.
# Get a free key at https://app.infura.io → Create New API Key → Web3 API
# Not secret - safe to expose in a static bundle, ⚠️ but do NOT commit your .env.
INFURA_API_KEY=

# ─── L2 RPC endpoints [OPTIONAL - only needed for L2 deployment] ──────────────
# Only required if deploying to an L2 production target via Foundry or Hardhat.
# Consumed by contracts/foundry.toml ([rpc_endpoints]) and hardhat.config.ts.
# Any of the providers above (Alchemy / Infura) can supply these URLs.
# Leave blank if you are only deploying to Ethereum Sepolia.
ARBITRUM_RPC_URL=
BASE_RPC_URL=
OPTIMISM_RPC_URL=

# ─── L2 block-explorer keys [OPTIONAL - only needed for L2 --verify] ──────────
# Only required if running --verify on an L2 deployment.
# Arbiscan  : arbiscan.io/register
# Basescan  : basescan.org/register
# Optimism  : optimistic.etherscan.io/register
ARBISCAN_API_KEY=
BASESCAN_API_KEY=
OPTIMISM_ETHERSCAN_API_KEY=

# ─── Fork testing [OPTIONAL] ──────────────────────────────────────────────────
# FORK_URL enables Hardhat's fork mode (npm run hardhat:test).
# When set, Hardhat forks from this chain instead of a fresh in-memory network.
#
# NOTE: Foundry fork tests (test/fork/**) do NOT use FORK_URL - they read
# SEPOLIA_RPC_URL directly via vm.envOr("SEPOLIA_RPC_URL"). Setting SEPOLIA_RPC_URL
# above is sufficient to activate both Hardhat and Foundry fork testing.
#
# Any RPC URL works - Sepolia for testnet parity, mainnet for full production
# parity. Leave blank to use a fresh in-memory chain (the default dev behavior).
#
# Tip: you can reuse SEPOLIA_RPC_URL here - just copy it:
#   FORK_URL=https://eth-sepolia.g.alchemy.com/v2/<key>
FORK_URL=

# Optional: pin the fork to a specific block number for reproducible results.
# Consumed by hardhat.config.ts and Foundry fork tests (vm.envOr("FORK_BLOCK_NUMBER")).
# Omit (or set to 0) to fork from the latest block.
FORK_BLOCK_NUMBER=

# ─── Frontend (Next.js / Reown AppKit + WalletConnect) [REQUIRED for frontend] ─
# Not secret - ends up visible in the browser bundle.
# Powers the Reown AppKit connect modal (src/lib/wagmi.ts). Without it the modal
# cannot pair over the WalletConnect relay, so QR / mobile flows (MetaMask,
# Phantom, Tangem, WalletConnect) fail; only injected and Coinbase remain usable.
# Get a free project ID at https://dashboard.reown.com (formerly
# cloud.walletconnect.com): create a project (type: AppKit), copy the Project ID.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ─── Frontend base path [OPTIONAL] ───────────────────────────────────────────
# Controls next.config.ts `basePath`. Leave empty to serve from root (/).
# Only set this if you need to host the frontend at a URL sub-path.
NEXT_BASE_PATH=

# ─── Vercel deployment [OPTIONAL - CI/CD only, not needed for local dev] ──────
# Used by .github/workflows/frontend-deploy.yml via `vercel` CLI.
#
# Setup steps:
#   1. Create a personal access token:
#        vercel.com/account/tokens → Create → scope to your team
#   2. Copy the token into VERCEL_TOKEN below.
#   3. Add it as a GitHub repository secret so CI/CD can use it:
#        GitHub repo → Settings → Secrets and variables → Actions
#        → New repository secret → Name: VERCEL_TOKEN → paste the value
#
# VERCEL_TOKEN - personal access token for the Vercel CLI.
# ⚠️  NEVER share or commit this value.
VERCEL_TOKEN=
#
# VERCEL_ORG_ID - team or personal account ID that owns the project.
#   Run `vercel link` from src/, then read src/.vercel/project.json → "orgId".
VERCEL_ORG_ID=
#
# VERCEL_PROJECT_ID - ID of the linked Vercel project.
#   Run `vercel link` from src/, then read src/.vercel/project.json → "projectId".
VERCEL_PROJECT_ID=

# ─── IPFS document storage (Pinata) [OPTIONAL] ───────────────────────────────
# JWT from Pinata (pinata.cloud → API Keys → + New Key → Files scoped).
# Powers the "Upload File" tab on the contract creation page.
# ⚠️ Not a secret when scoped to pinning only - safe to expose in a static bundle.
NEXT_PUBLIC_PINATA_JWT=

# Legacy Pinata key pair [OPTIONAL - not currently consumed by any code] ────────
# Reserved for future use (e.g. server-side Pinata calls that require HMAC auth).
# ⚠️  NEVER share or commit these values.
PINATA_API_KEY=
PINATA_API_SECRET=

# ─── Magic link (freelancer email onboarding) [REQUIRED for email feature] ────
# ⚠️  NEVER share or commit these values.
#
# MAGIC_LINK_SECRET - random secret used to HMAC-sign magic link tokens.
#   Generate one with: openssl rand -hex 32
MAGIC_LINK_SECRET=

# EMAIL_PROVIDER - server-side email provider for magic links and notifications.
#   Options: resend, brevo, postmark, log. Use log only for local development.
EMAIL_PROVIDER=resend

# EMAIL_FROM - provider-agnostic sender address. Provider-specific *_FROM values
#   remain supported for compatibility, but EMAIL_FROM wins when set.
EMAIL_FROM=

# RESEND_API_KEY - email delivery via Resend.
#   Get a free API key at https://resend.com/api-keys → Create API Key
#   Free tier: 3,000 emails/month, 100/day. No credit card required.
# ⚠️  NEVER share or commit this value.
RESEND_API_KEY=

# RESEND_FROM - sender address shown in the freelancer's inbox.
#   Must be from a domain you have verified in Resend (https://resend.com/domains).
#   During development, use the shared Resend test sender: onboarding@resend.dev
#	For Example: TrustLedger <noreply@yourdomain.com> 
RESEND_FROM=

# BREVO_API_KEY / BREVO_FROM - optional low-cost/free-tier fallback email
# provider for higher development/test daily limits than Resend.
BREVO_API_KEY=
BREVO_FROM=

# POSTMARK_SERVER_TOKEN / POSTMARK_FROM - optional transactional email provider
# for high-deliverability staging or production.
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM=
POSTMARK_MESSAGE_STREAM=outbound

# ─── AI contract summaries [OPTIONAL UNTIL ENABLED] ─────────────────────────
# AI_SUMMARY_PROVIDER - server-side provider for public contract summaries.
#   Options: disabled, groq, gemini. Keep disabled until provider data-use
#   controls are configured and monitoring is ready.
AI_SUMMARY_PROVIDER=disabled
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ─── Off-chain account sessions [REQUIRED for account persistence] ──────────
# Random HMAC secret for wallet-authenticated account sessions.
#   Generate one with: openssl rand -hex 32
ACCOUNT_SESSION_SECRET=
AUTH_JWT_SECRET=

# NEXT_PUBLIC_APP_URL - base URL used to build the magic link in the email.
#   Local dev     : http://localhost:3000
#   Production    : https://yourdomain.com
NEXT_PUBLIC_APP_URL=

# NEXT_PUBLIC_SOLANA_CLUSTER - optional public Solana cluster label for the
# native-program support path. Allowed: devnet, testnet, mainnet-beta, localnet.
# Defaults to devnet when unset.
NEXT_PUBLIC_SOLANA_CLUSTER=devnet

# NEXT_PUBLIC_SOLANA_PROGRAM_ID - public address of the deployed TrustLedger
# Solana native escrow program. Required before SOL escrow submission is
# enabled; safe to expose because Solana program IDs are public account
# addresses.
NEXT_PUBLIC_SOLANA_PROGRAM_ID=

# NEXT_PUBLIC_SITE_URL - origin advertised to wallets during WalletConnect/AppKit
#   pairing (must match the real page origin or mobile wallets like Tangem reject
#   the session). On the client the live origin is always used; this only sets the
#   SSR/build fallback. Optional - NEXT_PUBLIC_APP_URL is used as an alias when unset.
NEXT_PUBLIC_SITE_URL=

# ─── Contract notifications & deadline reminders [OPTIONAL for email feature] ──
# Reuse the same Resend setup above (RESEND_API_KEY / RESEND_FROM). These vars
# gate the lifecycle-notification API and the deadline-reminder cron.
# ⚠️  NEVER share or commit the secret values.
#
# NOTIFICATIONS_SECRET - bearer token guarding POST /api/notifications, which
#   sends lifecycle emails (new offer, work submitted, approval, dispute, rating,
#   deadline reminder). Trusted server callers must send
#   `Authorization: Bearer <NOTIFICATIONS_SECRET>`. Generate: openssl rand -hex 32
NOTIFICATIONS_SECRET=

# CRON_SECRET - bearer token for the daily deadline-reminder cron
#   (GET /api/cron/deadline-reminders, scheduled in src/vercel.json). Vercel
#   attaches `Authorization: Bearer <CRON_SECRET>` to cron invocations
#   automatically once this is set in the project. Generate: openssl rand -hex 32
#   Also recognized by the routing proxy (src/proxy.ts) so cron POSTs without a
#   browser Origin pass the CSRF check.
CRON_SECRET=

# INTERNAL_API_TOKEN - optional bearer token for trusted server-to-server or
#   webhook callers that hit state-changing /api/* routes without a browser
#   Origin. Requests sending `Authorization: Bearer <INTERNAL_API_TOKEN>` pass
#   the routing proxy CSRF check (src/proxy.ts -> @/security/serviceAuth).
#   Leave empty to allow only same-origin and cron traffic. Generate:
#   openssl rand -hex 32
INTERNAL_API_TOKEN=

# HEALTH_CHECK_TOKEN - bearer token for GET /api/health operational checks.
#   Runtime probes should use public GET /api/health/runtime instead. Trusted
#   admin callers can send `Authorization: Bearer <HEALTH_CHECK_TOKEN>`.
#   Generate: openssl rand -hex 32
HEALTH_CHECK_TOKEN=

# HEALTH_CHECK_ALLOWED_IPS - optional comma-separated IP allowlist for
#   GET /api/health. Prefer HEALTH_CHECK_TOKEN for dynamic/admin networks.
#   Example: 203.0.113.10,2001:db8::10
HEALTH_CHECK_ALLOWED_IPS=

# ADMIN_API_TOKEN - reserved shared admin token. GET /api/health accepts it as a
#   fallback while the full admin dashboard is still tracked in TODO.md.
#   Generate: openssl rand -hex 32
ADMIN_API_TOKEN=

# ─── Admin dashboard [OPTIONAL until operator dashboard is enabled] ──────────
# /en/admin is restricted by server-side auth. Do not expose these values with
# NEXT_PUBLIC_. Generate secrets with `openssl rand -hex 32`.
#
# ADMIN_SESSION_SECRET - HMAC key for signed admin sessions.
ADMIN_SESSION_SECRET=
#
# ADMIN_ALLOWED_IPS - optional comma-separated IP allowlist for /admin and
# /api/admin/*. Leave empty to allow any IP with valid admin auth.
# Example: 203.0.113.10,2001:db8::10
ADMIN_ALLOWED_IPS=
#
# ADMIN_WALLET_ADDRESSES - optional comma-separated wallet allowlist. When set,
# admin sign-in must include one of these wallet addresses.
ADMIN_WALLET_ADDRESSES=
#
# Bootstrap owner account. Provide project-specific values before generating
# ADMIN_BOOTSTRAP_PASSWORD_HASH; there are no hardcoded owner identities.
# Never commit ADMIN_BOOTSTRAP_PASSWORD. Generate the hash locally:
#   ADMIN_BOOTSTRAP_EMAIL='owner@example.com' ADMIN_BOOTSTRAP_USERNAME='owner' ADMIN_BOOTSTRAP_PASSWORD='your-long-password' node scripts/admin-bootstrap.mjs
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_USERNAME=
ADMIN_BOOTSTRAP_PASSWORD_HASH=
ADMIN_BOOTSTRAP_WALLET_ADDRESS=
#
# Additional admin accounts as JSON. Store passwordHash values only.
# Example:
# [{"email":"ops@example.com","username":"ops","passwordHash":"pbkdf2_sha256$...","roles":["operator"],"nonDeletable":false}]
ADMIN_ACCOUNTS_JSON=

# ─── Rust admin companion API [OPTIONAL for operator deployments] ────────────
# TRUSTLEDGER_ADMIN_API_BIND - bind address for `cargo run -p
#   trustledger-admin-api`. Local default: 127.0.0.1:4100. Container/Kubernetes
#   deployments should set this to 0.0.0.0:4100.
TRUSTLEDGER_ADMIN_API_BIND=127.0.0.1:4100
#
# TRUSTLEDGER_ADMIN_API_TOKEN - bearer token for protected Rust admin routes
#   such as GET /admin/summary. Generate: openssl rand -hex 32
TRUSTLEDGER_ADMIN_API_TOKEN=
#
# TRUSTLEDGER_ENV - non-secret environment label returned in redacted service
#   summaries. Example: local, preview, production.
TRUSTLEDGER_ENV=local

# NOTIFICATION_EMAILS - STOPGAP address→email map (JSON) the deadline cron uses
#   to know who to remind, until the Phase 6 off-chain account database lands.
#   Addresses with no entry are skipped (not emailed). Lowercase keys recommended.
#   Example: {"0xabc...":"freelancer@example.com","0xdef...":"client@example.com"}
NOTIFICATION_EMAILS=

# ─── Privacy analytics and monitoring [OPTIONAL] ─────────────────────────────
# TRUSTLEDGER_ANALYTICS_ENABLED - enables the server-side aggregate event
# collector at /api/analytics/events. No cookies, wallet addresses, raw IPs, raw
# user agents, or query strings are stored. Keep false until privacy/legal review
# and production notice are complete.
TRUSTLEDGER_ANALYTICS_ENABLED=false

# NEXT_PUBLIC_PRIVACY_ANALYTICS_ENABLED - enables the browser page-view/error
# beacon component. Must match TRUSTLEDGER_ANALYTICS_ENABLED; /api/health warns
# if they disagree.
NEXT_PUBLIC_PRIVACY_ANALYTICS_ENABLED=false

# TRUSTLEDGER_ANALYTICS_RETENTION_DAYS - aggregate in-memory event retention.
# Serverless instances may reset sooner; use a real privacy analytics provider
# for durable reporting.
TRUSTLEDGER_ANALYTICS_RETENTION_DAYS=30

# ─── Oracle rates [OPTIONAL for payment display data] ──────────────────────
# ORACLE_PRICE_SOURCE_URL - server-side price source compatible with the
#   CoinGecko simple price response shape. Defaults to:
#   https://api.coingecko.com/api/v3/simple/price
ORACLE_PRICE_SOURCE_URL=

# ORACLE_RATE_TTL_MS - server-side cache TTL for GET /api/oracle/rates.
#   Defaults to 60000 and is capped at 3600000.
ORACLE_RATE_TTL_MS=

# ─── Source code link [OPTIONAL] ─────────────────────────────────────────────
# NEXT_PUBLIC_GITHUB_URL - link to the source code repository shown in the navbar.
#   Also powers the public GitHub stats section on /status, but only when GitHub
#   reports the repository as public.
#   On Vercel this is constructed automatically from the VERCEL_GIT_REPO_OWNER and
#   VERCEL_GIT_REPO_SLUG system env vars - no manual config needed there.
#   Set this only for local development or non-Vercel deployments.
NEXT_PUBLIC_GITHUB_URL=

# GITHUB_TOKEN - optional server-only token for higher GitHub API rate limits.
#   The public stats endpoint still hides private repositories even with a token.
GITHUB_TOKEN=

# ─── Frontend contract addresses [REQUIRED for deployed frontend reads] ───────
# Public deployed contract addresses and deploy blocks used by src/lib/wagmi.ts.
# Deploy scripts and `npm run sync-env` can populate these from
# artifacts/deployed-addresses.json after a deployment.
NEXT_PUBLIC_TRUSTLEDGER_ADDRESS=
NEXT_PUBLIC_ARBITRATION_ADDRESS=
NEXT_PUBLIC_JUROR_REGISTRY_ADDRESS=
NEXT_PUBLIC_REPUTATION_REGISTRY_ADDRESS=
NEXT_PUBLIC_TRUSTLEDGER_DEPLOY_BLOCK=

# Network-specific contract addresses. Set Sepolia values for the current
# testnet deployment; set L2 values only after deploying to those networks.
NEXT_PUBLIC_TRUSTLEDGER_ADDRESS_SEPOLIA=
NEXT_PUBLIC_ARBITRATION_ADDRESS_SEPOLIA=
NEXT_PUBLIC_JUROR_REGISTRY_ADDRESS_SEPOLIA=
NEXT_PUBLIC_REPUTATION_REGISTRY_ADDRESS_SEPOLIA=
NEXT_PUBLIC_TRUSTLEDGER_DEPLOY_BLOCK_SEPOLIA=
NEXT_PUBLIC_TRUSTLEDGER_ADDRESS_ARBITRUM=
NEXT_PUBLIC_ARBITRATION_ADDRESS_ARBITRUM=
NEXT_PUBLIC_JUROR_REGISTRY_ADDRESS_ARBITRUM=
NEXT_PUBLIC_REPUTATION_REGISTRY_ADDRESS_ARBITRUM=
NEXT_PUBLIC_TRUSTLEDGER_DEPLOY_BLOCK_ARBITRUM=
NEXT_PUBLIC_TRUSTLEDGER_ADDRESS_BASE=
NEXT_PUBLIC_ARBITRATION_ADDRESS_BASE=
NEXT_PUBLIC_JUROR_REGISTRY_ADDRESS_BASE=
NEXT_PUBLIC_REPUTATION_REGISTRY_ADDRESS_BASE=
NEXT_PUBLIC_TRUSTLEDGER_DEPLOY_BLOCK_BASE=
NEXT_PUBLIC_TRUSTLEDGER_ADDRESS_OPTIMISM=
NEXT_PUBLIC_ARBITRATION_ADDRESS_OPTIMISM=
NEXT_PUBLIC_JUROR_REGISTRY_ADDRESS_OPTIMISM=
NEXT_PUBLIC_REPUTATION_REGISTRY_ADDRESS_OPTIMISM=
NEXT_PUBLIC_TRUSTLEDGER_DEPLOY_BLOCK_OPTIMISM=

# Public token-address overrides. Leave blank to use the chain defaults in
# src/lib/wagmi.ts. These are public token contract addresses, not secrets.
NEXT_PUBLIC_USDC_ADDRESS_SEPOLIA=
NEXT_PUBLIC_USDC_ADDRESS_ARBITRUM=
NEXT_PUBLIC_USDC_ADDRESS_BASE=
NEXT_PUBLIC_USDC_ADDRESS_OPTIMISM=

# Dual-asset staking. Deployed StakingVault (USDC staking) addresses, published by
# `npm run foundry:deploy:staking:sepolia`. No hardcoded default: an unset/zero
# value means USDC staking is not yet configured on that network and the UI shows
# an "unavailable" state instead of a mocked path. Source: src/lib/wagmi.ts.
# The unsuffixed var also wires the local Hardhat/Anvil chain (31337) for local
# end-to-end testing.
NEXT_PUBLIC_STAKING_VAULT_ADDRESS=
NEXT_PUBLIC_STAKING_VAULT_ADDRESS_SEPOLIA=
NEXT_PUBLIC_STAKING_VAULT_ADDRESS_ARBITRUM=
NEXT_PUBLIC_STAKING_VAULT_ADDRESS_BASE=
NEXT_PUBLIC_STAKING_VAULT_ADDRESS_OPTIMISM=

# StakingVault deploy-time configuration consumed by contracts/script/DeployStaking.s.sol
# (server-side only; never exposed to the browser). STAKING_USDC_ADDRESS is required and
# must be the real USDC token on the target network — there is no default, so a missing or
# zero value fails the deploy loudly rather than creating an unusable vault. STAKING_REWARDS_TOKEN
# defaults to STAKING_USDC_ADDRESS; STAKING_VAULT_OWNER defaults to the broadcasting deployer
# (set it to a multisig to hand off ownership at deploy time).
STAKING_USDC_ADDRESS=
STAKING_REWARDS_TOKEN=
STAKING_VAULT_OWNER=

# StakingVault reward-funding configuration consumed by contracts/script/FundStaking.s.sol
# (`npm run foundry:fund:staking:sepolia`). STAKING_VAULT_ADDRESS is the deployed vault to fund;
# STAKING_REWARD_AMOUNT is the reward in the token's smallest units (USDC has 6 decimals, so
# 1000 USDC = 1000000000). The broadcaster must be the vault owner and already hold the reward
# tokens. Funding opens a distribution over the vault's rewardsDuration (default 7 days).
STAKING_VAULT_ADDRESS=
STAKING_REWARD_AMOUNT=

# NEXT_PUBLIC_SOLANA_STAKING_PROGRAM_ID - public address of the deployed native
# SOL staking program (programs/solana-staking). SOL staking stays disabled until
# this is set to a valid program id. Safe to expose; program ids are public.
NEXT_PUBLIC_SOLANA_STAKING_PROGRAM_ID=

# NEXT_PUBLIC_SOLANA_RPC_URL - optional RPC override for Solana reads/transactions.
# Falls back to the cluster default (see NEXT_PUBLIC_SOLANA_CLUSTER) when unset.
NEXT_PUBLIC_SOLANA_RPC_URL=

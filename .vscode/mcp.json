{
	"servers": {
		"serena": {
			"type": "stdio",
			"command": "serena",
			"args": ["start-mcp-server", "--context=vscode", "--project", "${workspaceFolder}"]
		},
		"nexus": {
			"type": "stdio",
			"command": "node",
			"args": ["./scripts/nexus-mcp.js", "server", "--project", "."],
			"env": {
				"NODE_ENV": "development",
				"NO_COLOR": "1"
			}
		}
	}
}

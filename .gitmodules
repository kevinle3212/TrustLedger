# Foundry's standard Solidity test helpers live under `contracts/lib/forge-std`,
# but that directory is vendored in this repository rather than tracked as a
# git submodule. Keep it out of this file unless it is intentionally converted
# back to a 160000 gitlink.

# OpenZeppelin contract library used by TrustLedger Solidity contracts and
# mocks. Keep this pinned through the git submodule commit, not a floating tag.
[submodule "contracts/lib/openzeppelin-contracts"]
	path = contracts/lib/openzeppelin-contracts
	url = https://github.com/OpenZeppelin/openzeppelin-contracts

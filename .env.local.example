# ─── TrustLedger .env.local (Vercel-managed) ─────────────────────────────────
#
# ⚠️  You normally do NOT create this file by hand.
# The Vercel CLI generates `.env.local` for you when you run:
#   vercel link        # once, to link this repo to the Vercel project
#   vercel env pull     # writes/refreshes .env.local from the project's env vars
#   vercel pull         # also pulls project settings + env into .vercel/ and .env.local
#
# This `.env.local.example` exists only to document the SHAPE of that generated
# file so you know what to expect. Treat the real `.env.local` as disposable —
# re-run `vercel env pull` any time it drifts. It is git-ignored.
#
# How env vars are sourced in this project:
#   - Local frontend dev (npm run dev:frontend) reads the ROOT `.env` file via
#     parseRootEnv() in src/next.config.ts — see `.env.example` for that file.
#   - `.env.local` is only required for `vercel dev` and for matching the exact
#     env set that runs in Vercel Preview/Production.
#   - When both exist, Next.js gives `.env.local` precedence over `.env`.
#
# Never commit your real `.env.local` — `.gitignore` already excludes it.

# ─── Auto-injected by the Vercel CLI ─────────────────────────────────────────
# VERCEL_OIDC_TOKEN — short-lived OpenID Connect token written by `vercel env
# pull`. Lets local code authenticate to Vercel/marketplace resources without a
# long-lived secret. Auto-generated and auto-rotated — do not set it manually.
VERCEL_OIDC_TOKEN=

# ─── Frontend (Next.js / WalletConnect) [REQUIRED for frontend] ───────────────
# Not secret — ends up visible in the browser bundle.
# Free project ID from https://cloud.walletconnect.com (project type: App).
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ─── Deployed contract addresses [REQUIRED to talk to the contracts] ─────────
# The 0x… addresses of the deployed contracts the frontend reads/writes.
# On Vercel these are set per-environment; `vercel env pull` brings them down.
# `.github/workflows/deploy.yml` updates them automatically after each deploy.
NEXT_PUBLIC_TRUSTLEDGER_ADDRESS=
NEXT_PUBLIC_ARBITRATION_ADDRESS=
NEXT_PUBLIC_JUROR_REGISTRY_ADDRESS=
NEXT_PUBLIC_REPUTATION_REGISTRY_ADDRESS=
NEXT_PUBLIC_TRUSTLEDGER_DEPLOY_BLOCK=

# Optional chain-specific production overrides. Sepolia is auto-updated by
# .github/workflows/deploy.yml after contract deploys.
NEXT_PUBLIC_TRUSTLEDGER_ADDRESS_SEPOLIA=
NEXT_PUBLIC_ARBITRATION_ADDRESS_SEPOLIA=
NEXT_PUBLIC_JUROR_REGISTRY_ADDRESS_SEPOLIA=
NEXT_PUBLIC_REPUTATION_REGISTRY_ADDRESS_SEPOLIA=
NEXT_PUBLIC_TRUSTLEDGER_DEPLOY_BLOCK_SEPOLIA=

# ─── IPFS document storage (Pinata) [OPTIONAL] ───────────────────────────────
# JWT from Pinata (pinata.cloud → API Keys → + New Key → Files scoped).
# Powers the "Upload File" tab on the contract creation page.
# Not a secret when scoped to pinning only — safe to expose in a static bundle.
NEXT_PUBLIC_PINATA_JWT=

# ─── App URLs [OPTIONAL] ─────────────────────────────────────────────────────
# NEXT_PUBLIC_APP_URL — base URL used to build magic links in onboarding emails.
#   On Vercel this is derived automatically; set it only for local dev.
#   Local dev: http://localhost:3000
NEXT_PUBLIC_APP_URL=
# NEXT_PUBLIC_SITE_URL — origin advertised to wallets during WalletConnect/AppKit
#   pairing. Optional; falls back to NEXT_PUBLIC_APP_URL, then the live origin.
NEXT_PUBLIC_SITE_URL=
#
# NEXT_PUBLIC_GITHUB_URL — source repo link shown in the navbar.
#   On Vercel this is built from VERCEL_GIT_REPO_OWNER / VERCEL_GIT_REPO_SLUG.
NEXT_PUBLIC_GITHUB_URL=

{
	"mcpServers": {
		"serena": {
			"type": "stdio",
			"command": "serena",
			"tools": ["*"],
			"args": ["start-mcp-server", "--context=copilot-cli", "--project-from-cwd"],
			"env": {
				"NO_COLOR": "1"
			}
		},
		"nexus": {
			"type": "stdio",
			"command": "node",
			"tools": ["*"],
			"args": ["./scripts/nexus-mcp.js", "server", "--project", "."],
			"env": {
				"NODE_ENV": "development",
				"NO_COLOR": "1",
				"NEXUS_MCP_TIMEOUT_MS": "120000",
				"NEXUS_MAX_TREE_SITTER_TS_BYTES": "25000"
			}
		}
	}
}

# ─── Editor / tool local config ──────────────────────────────────────────────
.claude/
.sixth/
.vscode-test/

# ─── Nexus code graph index (generated by nexus-graph index) ──────────────────
.nexus/

# ─── Foundry build output ─────────────────────────────────────────────────────
contracts/out/
contracts/cache/
contracts/broadcast/

# ─── Hardhat build output ─────────────────────────────────────────────────────
artifacts/
# The deployed addresses are not sensitive and can be published without an issue.
!artifacts/deployed-addresses.json
hardhat-cache/
.hardhat-out/

# ─── TypeScript / Node ────────────────────────────────────────────────────────
node_modules/
dist/
*.tsbuildinfo
.eslintcache
.stylelintcache
.node_repl_history

# ─── TypeScript debug output (generated by npm run debug:files) ───────────────
trace/
*.cpuprofile

# ─── Environment / secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Package manager caches ───────────────────────────────────────────────────
.npm
.pnpm-store
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.pnp.*

# ─── Coverage ─────────────────────────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── OS generated files ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem

# ─── Next.js (src/) ───────────────────────────────────────────────────────────
src/.next/
src/out/
src/build
src/next-env.d.ts

# ─── Vercel ───────────────────────────────────────────────────────────────────
.vercel

# ─── Local testing ─────────────────────────────────────────────
testing/

# ─── Deprecated / phased-out assets ──────────────────────────────────────────
**/deprecated/

# ─── Editor / tool local config ──────────────────────────────────────────────
.claude/
.serena/
.sixth/
.vscode-test/

# ─── Nexus code graph index (generated by nexus-graph index) ──────────────────
.nexus/

# ─── Foundry build output ─────────────────────────────────────────────────────
contracts/out/
contracts/cache/
contracts/broadcast/

# ─── Hardhat build output ────────────────────────────────────────────────────
# deployed-addresses.json is regenerated on every deploy and pushed to Vercel
# as NEXT_PUBLIC_TRUSTLEDGER_ADDRESS by deploy.yml - no need to commit it.
artifacts/
hardhat-cache/
.hardhat-out/

# ─── TypeScript / Node ────────────────────────────────────────────────────────
node_modules/
dist/
*.tsbuildinfo
.eslintcache
.stylelintcache
.node_repl_history

# ─── TypeScript debug output (generated by npm run debug:files) ───────────────
trace/
*.cpuprofile

# ─── Environment / secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.local.example

# ─── Package manager caches ───────────────────────────────────────────────────
.npm
.pnpm-store
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.pnp.*

# ─── Coverage ─────────────────────────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── OS generated files ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem

# ─── Next.js (src/) ───────────────────────────────────────────────────────────
# /.next is the repo-root symlink `vercel-build` points at src/.next so Vercel
# finds the output; src/.next/ is the actual Next.js build directory.
/.next
src/.next/
src/out/
src/build/
src/next-env.d.ts

# ─── Vercel ───────────────────────────────────────────────────────────────────
.vercel

# ─── Local testing ─────────────────────────────────────────────
testing/

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
.venv/
venv/
.mypy_cache/

# ─── MkDocs ──────────────────────────────────────────────────────────────────
site/

# ─── Private notes (the public NOTES.md is committed; *.local.md is not) ───────
NOTES.local.md

# ─── Miscellaneous ───────────────────────────────────────────────────────────
.idea/
assets/presentation/

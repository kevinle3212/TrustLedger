# ─── Deprecated / phased-out assets ──────────────────────────────────────────
**/deprecated/

# ─── Editor / tool local state ───────────────────────────────────────────────
.claude/*
!.claude/commands/
!.claude/commands/**
!.claude/settings.json
**/.serena/cache/
**/.serena/project.local.yml

# ─── Nexus code graph index (generated by nexus-graph index) ─────────────────
**/.nexus/graph.db*

# ─── Foundry build output ─────────────────────────────────────────────────────
contracts/out/
contracts/cache/
contracts/broadcast/
contracts/foundry-sandbox/cache/

# ─── Hardhat build output ────────────────────────────────────────────────────
# deployed-addresses.json is regenerated on every deploy and pushed to Vercel
# as NEXT_PUBLIC_TRUSTLEDGER_ADDRESS by deploy.yml - no need to commit it.
artifacts/
hardhat-cache/
.hardhat-out/

# ─── TypeScript / Node ────────────────────────────────────────────────────────
node_modules/
dist/
*.tsbuildinfo
.eslintcache
.stylelintcache
.node_repl_history

# ─── Rust ─────────────────────────────────────────────────────────────────────
target/

# ─── TypeScript debug output (generated by npm run debug:files) ───────────────
trace/
*.cpuprofile

# ─── SWC policy manifests and generated native cache ─────────────────────────
.swc/*
!.swc/
!.swc/.gitignore
!.swc/README.md
!.swc/policy.json
src/.swc/*
!src/.swc/
!src/.swc/.gitignore
!src/.swc/README.md
!src/.swc/config.json
!src/.swc/plugins/
!src/.swc/plugins/README.md
!src/.swc/plugins/*/
!src/.swc/plugins/*/README.md
!src/.swc/plugins/*/manifest.json

# ─── Environment / secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.local.example
k8s/secret.yaml
k8s/*.secret.yaml
.admin-bootstrap.generated.json

# ─── Package manager caches ───────────────────────────────────────────────────
.npm
.pnpm-store
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.pnp.*

# ─── Coverage ─────────────────────────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/

# ─── Playwright test output and local browser state ──────────────────────────
src/test-results/
src/playwright-report/
src/blob-report/
src/playwright/.cache/
src/playwright/.auth/
src/.playwright-cli/

# ─── Lighthouse CI ────────────────────────────────────────────────────────────
# Transient LHCI run output (reports, manifest). Never a source of failures.
.lighthouseci/
src/.lighthouseci/

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── OS generated files ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem

# ─── Next.js (src/) ───────────────────────────────────────────────────────────
# /.next is the repo-root symlink `vercel-build` points at src/.next so Vercel
# finds the output; src/.next/ is the actual Next.js build directory.
/.next
src/.next/
src/out/
src/build/
src/next-env.d.ts

# ─── Vercel ───────────────────────────────────────────────────────────────────
.vercel/*

# ─── Local testing ────────────────────────────────────────────────────────────
testing/

# ─── Project-local temporary files ────────────────────────────────────────────
# Agents and scripts should prefer ./tmp over system /tmp for reproducibility.
tmp/

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
.venv/
.venv-docs/
venv/
.mypy_cache/

# ─── MkDocs ──────────────────────────────────────────────────────────────────
site/

# ─── Private notes (the public NOTES.md is committed; *.local.md is not) ───────
NOTES.local.md

# ─── Impeccable UI audit snapshots and live-mode runtime ─────────────────────
.impeccable/live/*
!.impeccable/live/config.json

# ─── Miscellaneous ───────────────────────────────────────────────────────────
.idea/
assets/presentation/

{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "trustledger",
	"version": "0.1.0",
	"description": "A smart-contract built on the Ethereum blockchain.",
	"private": true,
	"keywords": [
		"ethereum",
		"smart-contract",
		"blockchain",
		"oregon-blockchain-group",
		"obg",
		"contract",
		"ledger",
		"trustledger",
		"solidity",
		"hardhat",
		"foundry",
		"escrow",
		"dapp",
		"web3",
		"defi",
		"freelance",
		"dispute-resolution",
		"openzeppelin",
		"sepolia"
	],
	"homepage": "https://github.com/kevinle3212/TrustLedger#readme",
	"bugs": {
		"url": "https://github.com/kevinle3212/TrustLedger/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kevinle3212/TrustLedger.git"
	},
	"license": "Apache-2.0",
	"author": "Kevin Le",
	"contributors": [
		"Kellen Snider"
	],
	"engines": {
		"node": ">=22.0.0"
	},
	"scripts": {
		"compile": "TS_NODE_PROJECT=tsconfig.hardhat.json hardhat compile",
		"hardhat:test": "TS_NODE_PROJECT=tsconfig.hardhat.json hardhat test",
		"hardhat:gas": "REPORT_GAS=true TS_NODE_PROJECT=tsconfig.hardhat.json hardhat test",
		"hardhat:check-balance": "TS_NODE_PROJECT=tsconfig.hardhat.json hardhat run scripts/check-balance.ts --network sepolia",
		"node": "hardhat node",
		"hardhat:deploy:local": "TS_NODE_PROJECT=tsconfig.hardhat.json hardhat run scripts/deploy.ts --network localhost",
		"hardhat:deploy:sepolia": "TS_NODE_PROJECT=tsconfig.hardhat.json hardhat run scripts/deploy.ts --network sepolia",
		"hardhat:wire-reputation:sepolia": "TS_NODE_PROJECT=tsconfig.hardhat.json hardhat run scripts/wire-reputation-registry.ts --network sepolia",
		"sync:frontend:env": "TS_NODE_PROJECT=tsconfig.hardhat.json hardhat run scripts/sync-frontend-env.ts",
		"start:deploy:local": "npm run compile && (npm run node &) && sleep 2 && npm run hardhat:deploy:local",
		"start:deploy:dry-run": "npm run foundry:build && npm run foundry:deploy:sepolia:dry-run",
		"start:deploy:hardhat": "npm run compile && npm run hardhat:deploy:sepolia",
		"start:deploy:foundry": "npm run foundry:build && npm run foundry:deploy:sepolia",
		"lint": "npm run lint:config && npm run lint:ts && npm run lint:js && npm run lint:styles && npm run lint:knip && npm run lint:sol && npm run lint:forge && npm run lint:md && npm run lint:cursor && npm run lint:k8s && npm run lint:logs",
		"lint:frontend": "cd src && npm run lint:frontend",
		"swc:populate": "node tools/ensure-swc-cache.mjs",
		"prebuild:frontend": "npm run swc:populate",
		"build:frontend": "cd src && npm run build:frontend",
		"prebuild": "npm run swc:populate",
		"build": "npm run compile && npm run foundry:build && npm run build:frontend",
		"test": "npm run foundry:test && npm run hardhat:test && npm run test:frontend:unit",
		"test:unit": "cd src && npm run test:unit",
		"test:frontend:unit": "cd src && npm run test:unit",
		"test:e2e": "cd src && npm run test:e2e",
		"typecheck": "npm run typecheck:hardhat && npm run typecheck:frontend",
		"typecheck:hardhat": "tsc -p tsconfig.hardhat.json --noEmit",
		"typecheck:frontend": "cd src && npx tsc --noEmit",
		"doctor": "cd src && npm run doctor",
		"impeccable": "npm run doctor && npm run lint:frontend && npm run test:e2e",
		"quality": "npm run logs:check && npm run lint && npm run typecheck && npm run test",
		"quality:all": "npm run quality && npm run build && npm run impeccable && npm run docs:build && npm run docs:links",
		"fix": "npm run fix:ts && npm run fix:prettier && npm run fix:frontend",
		"fix:frontend": "cd src && npm run fix:frontend",
		"fix:ts": "eslint --fix 'test/**/*.ts' 'scripts/**/*.ts' 'hardhat.config.ts'",
		"fix:prettier": "prettier --write .",
		"lint:config": "eslint eslint.config.mjs eslint.scripts.config.mjs commitlint.config.js",
		"lint:sol": "solhint --disc --max-warnings 0 'contracts/src/**/*.sol' 'contracts/test/**/*.sol' 'contracts/script/**/*.sol'",
		"lint:forge": "cd contracts && forge fmt --check && forge lint",
		"lint:md": "markdownlint-cli2 \"**/*.md\" \"#NOTES.local.md\" \"#contracts/lib\" \"#contracts/out\" \"#contracts/cache\" \"#artifacts\" \"#dist\" \"#node_modules\" \"#src/node_modules\" \"#.next\" \"#src/.next\" \"#.vercel/output\" \"#.venv-docs\" \"#.claude\" \"#.sixth\" \"#site\" \"#testing\" \"#src/skills\" \"#src/.agents\" \"#src/.claude\"",
		"lint:logs": "markdownlint-cli2 \"logs/**/*.md\" \"#logs/**/node_modules\"",
		"logs:check": "node tools/check-logs.mjs",
		"logs:prune": "node tools/check-logs.mjs --prune",
		"docs:build": "bash tools/mkdocs-build-strict.sh",
		"docs:links": "node tools/check-doc-links.mjs",
		"docs:links:external": "node tools/check-doc-links.mjs --external",
		"lint:cursor": "prettier --check \".cursor/**/*.md\" && prettier --check --parser markdown \".cursor/**/*.mdc\" && markdownlint-cli2 \".cursor/**/*.md\" \".cursor/**/*.mdc\"",
		"lint:k8s": "prettier --check \"k8s/**/*.yaml\" && kubectl kustomize k8s >/dev/null",
		"k8s:secret:generate": "node tools/generate-k8s-secret.mjs",
		"lint:js": "eslint -c eslint.scripts.config.mjs 'scripts/**/*.js'",
		"lint:ts": "eslint 'test/**/*.ts' 'scripts/**/*.ts' 'hardhat.config.ts'",
		"lint:styles": "stylelint \"src/app/**/*.{css,scss}\"",
		"lint:knip": "knip --strict --workspace . && cd src && npx knip --strict",
		"lint:prettier": "prettier --check .",
		"lint:py": "mypy utils/generate_contract.py scripts/models/github_models.py",
		"debug:files": "tsc -p tsconfig.debug.json --generateTrace ./trace --generateCpuProfile ./profile.cpuprofile",
		"foundry:gas": "cd contracts && forge test --gas-report",
		"foundry:build": "cd contracts && forge build",
		"foundry:test": "node tools/foundry-sandbox.mjs test --offline --no-match-path 'test/fork/**'",
		"foundry:test:staging": "cd contracts && FOUNDRY_PROFILE=staging forge test -vvv",
		"foundry:test:fork": "node tools/foundry-sandbox.mjs test --match-path 'test/fork/**'",
		"foundry:test:fork:live": "TRUSTLEDGER_ALLOW_FORK_RPC=1 node tools/foundry-sandbox.mjs test --match-path 'test/fork/**'",
		"foundry:deploy:sepolia": "set -a && . ./.env && set +a && cd contracts && forge script script/Deploy.s.sol --rpc-url sepolia --private-key \"$DEPLOYER_PRIVATE_KEY\" --broadcast --verify -vvvv",
		"foundry:deploy:sepolia:dry-run": "set -a && . ./.env && set +a && cd contracts && forge script script/Deploy.s.sol --rpc-url sepolia --private-key \"$DEPLOYER_PRIVATE_KEY\" -vvvv",
		"demo:good": "TS_NODE_PROJECT=tsconfig.hardhat.json hardhat run scripts/demo/demo-good.ts --network localhost --no-compile",
		"demo:bad": "TS_NODE_PROJECT=tsconfig.hardhat.json hardhat run scripts/demo/demo-bad.ts --network localhost --no-compile",
		"demo:jurors": "TS_NODE_PROJECT=tsconfig.hardhat.json hardhat run scripts/demo/demo-jurors.ts --network localhost --no-compile",
		"demo:scenario": "TS_NODE_PROJECT=tsconfig.hardhat.json hardhat run scripts/demo/demo-scenarios.ts --network localhost --no-compile",
		"demo:stablecoin": "TS_NODE_PROJECT=tsconfig.hardhat.json hardhat run scripts/demo/demo-stablecoin.ts --network localhost --no-compile",
		"demo:run": "bash scripts/run-demo.sh",
		"models:install": "python3 -m pip install -r scripts/models/requirements.txt",
		"models:run": "python3 scripts/models/github_models.py --scenario all --skip-rate-limit",
		"models:run:summarize": "python3 scripts/models/github_models.py --scenario summarize",
		"models:run:generate": "python3 scripts/models/github_models.py --scenario generate",
		"models:run:qa": "python3 scripts/models/github_models.py --scenario qa",
		"models:run:dispute": "python3 scripts/models/github_models.py --scenario dispute",
		"models:run:risk": "python3 scripts/models/github_models.py --scenario risk",
		"models:run:reputation": "python3 scripts/models/github_models.py --scenario reputation",
		"models:eval": "bash scripts/models/eval-prompts.sh",
		"deploy:vercel": "vercel --prod",
		"prepare": "husky",
		"nexus:index": "node scripts/nexus-mcp.js index --project .",
		"nexus:server": "node scripts/nexus-mcp.js server --project .",
		"nexus:viz": "nexus-graph viz --project .",
		"cache:clear": "npm run cache:clear:eslint && npm run cache:clear:prettier && npm run cache:clear:npm && npm run cache:clear:hardhat && npm run cache:clear:typechain",
		"cache:clear:eslint": "find . -name '.eslintcache' -maxdepth 3 | grep -v node_modules | xargs rm -f",
		"cache:clear:prettier": "find . -name '.prettiercache' -maxdepth 3 | grep -v node_modules | xargs rm -f",
		"cache:clear:npm": "npm cache clean --force",
		"cache:clear:hardhat": "rm -rf artifacts cache typechain-types",
		"cache:clear:typechain": "rm -rf typechain-types",
		"audit:root": "npm audit",
		"audit:root:prod": "npm audit --omit=dev",
		"audit:frontend": "cd src && npm audit",
		"audit:frontend:prod": "cd src && npm audit --omit=dev",
		"security:alerts": "gh api repos/kevinle3212/TrustLedger/code-scanning/alerts?state=open --paginate | jq '[.[] | {number: .number, rule: .rule.id, severity: .rule.severity, description: .rule.description, file: .most_recent_instance.location.path, line: .most_recent_instance.location.start_line, url: .html_url}]'",
		"security:dependabot": "gh api repos/kevinle3212/TrustLedger/dependabot/alerts?state=open --paginate | jq '[.[] | {number: .number, package: .dependency.package.name, severity: .security_advisory.severity, summary: .security_advisory.summary, url: .html_url}]'",
		"security": "npm run security:alerts && npm run security:dependabot"
	},
	"devDependencies": {
		"@commitlint/cli": "^21.0.2",
		"@commitlint/config-conventional": "^21.0.2",
		"@costline/nexus-graph": "^0.1.1",
		"@eslint/js": "^10.0.1",
		"@nomicfoundation/hardhat-ethers": "^3.1.3",
		"@nomicfoundation/hardhat-toolbox": "^5.0.0",
		"@tsconfig/strictest": "^2.0.8",
		"@types/node": "^25.7.0",
		"dotenv": "^17.4.2",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"hardhat": "^2.28.6",
		"husky": "^9.1.7",
		"knip": "^6.16.1",
		"markdownlint-cli2": "^0.22.1",
		"prettier": "^3.8.3",
		"solhint": "^6.2.1",
		"stylelint": "^17.13.0",
		"stylelint-config-standard-scss": "^17.0.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1"
	},
	"dependencies": {
		"@openzeppelin/contracts": "^5.6.1"
	},
	"overrides": {
		"ws": "8.20.1",
		"serialize-javascript": "7.0.5",
		"tmp": "0.2.7",
		"cookie": "0.7.2",
		"uuid": "11.1.1",
		"lodash": "4.18.1",
		"undici": "6.26.0",
		"ethjs-unit": {
			"bn.js": "4.12.3"
		},
		"number-to-bn": {
			"bn.js": "4.12.3"
		}
	}
}

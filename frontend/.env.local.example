# Copy this file to .env.local and fill in values before running npm run dev or npm run build.
# Neither value is sensitive — both end up visible in the browser bundle.

# Get a free project ID at https://cloud.walletconnect.com
# Create a project (type: App), copy the Project ID from the dashboard.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Deployed TrustLedger contract address on Ethereum Sepolia (chain ID 11155111).
# Obtained after running the deploy workflow (deploy.yml) in GitHub Actions.
NEXT_PUBLIC_TRUSTLEDGER_ADDRESS=0x0000000000000000000000000000000000000000

# ─── npm configuration (repo root) ───────────────────────────────────────────
# Raise network timeouts so large/slow installs (Foundry, Playwright browsers,
# native builds) don't abort on a slow connection. Values are milliseconds.
fetch-timeout=150000
fetch-retry-maxtimeout=150000
# Write npm's own debug logs under logs/npm (logs/ is gitignored) instead of the
# global npm cache, keeping run output with the rest of the project's logs.
logs-dir=logs/npm
# Quieter install output; warnings and errors still surface.
loglevel=warn
# Supply-chain delay: only install package versions published more than 7 days
# ago, giving compromised releases time to be caught and yanked (npm-native).
min-release-age=7

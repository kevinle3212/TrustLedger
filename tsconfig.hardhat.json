{
	"compilerOptions": {
		"target": "ES2024",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"rootDir": ".",
		"types": ["node", "mocha"],
		"paths": {
			"ethers": ["./node_modules/ethers/lib.esm/index"]
		},
		"esModuleInterop": true,
		"strict": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"noEmit": true
	},
	"include": ["hardhat.config.ts", "test/**/*.ts", "scripts/**/*.ts"]
}
